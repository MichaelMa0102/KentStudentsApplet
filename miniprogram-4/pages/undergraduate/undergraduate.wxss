.page {
  min-height: 100vh;
  background: #f0f0f0;
  padding-bottom: 40rpx;
}

.header-bg {
  background: linear-gradient(180deg, #ffe8ef 0%, #fff5f8 45%, #f5f5f5 100%);
  padding: 20rpx 24rpx 24rpx;
}

.main-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.main-tab {
  padding: 12rpx 22rpx;
  font-size: 24rpx;
  color: #666;
  background: #fff;
  border-radius: 999rpx;
  border: 1rpx solid #eee;
}

.main-tab--on {
  color: #333;
  font-weight: 600;
  background: #e8e8e8;
  border-color: #ddd;
}

.filter-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.filter-pill {
  font-size: 24rpx;
  color: #555;
  background: rgba(255, 255, 255, 0.85);
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
}

.filter-help {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  border: 1rpx solid #ccc;
  border-radius: 50%;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-inner {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 999rpx;
  padding: 0 20rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 72rpx;
}

.search-btn {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #ff4757;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 50%;
  box-shadow: 0 4rpx 12rpx rgba(255, 71, 87, 0.35);
}

.chip-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 12rpx;
}

.chip-scroll--2 {
  margin-bottom: 0;
}

.chip-row {
  display: inline-flex;
  gap: 28rpx;
  padding: 8rpx 4rpx 12rpx;
}

.chip {
  font-size: 26rpx;
  color: #666;
  padding-bottom: 8rpx;
  border-bottom: 4rpx solid transparent;
  flex-shrink: 0;
}

.chip--sm {
  font-size: 24rpx;
}

.chip--on {
  color: #2b6cff;
  font-weight: 600;
  border-bottom-color: #2b6cff;
}

.table-card {
  margin: 0 20rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.table-head {
  display: flex;
  align-items: center;
  padding: 22rpx 20rpx;
  background: #fafafa;
  border-bottom: 1rpx solid #eee;
}

.th {
  font-size: 26rpx;
  color: #888;
  font-weight: 600;
}

.th-rank {
  width: 88rpx;
  flex-shrink: 0;
  text-align: center;
}

.th-school {
  flex: 1;
  padding-left: 8rpx;
}

.th-count {
  width: 140rpx;
  flex-shrink: 0;
  text-align: right;
  padding-right: 8rpx;
}

.list-scroll {
  max-height: calc(100vh - 520rpx);
}

.table-row {
  display: flex;
  align-items: center;
  padding: 22rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-row:active {
  background: #f9f9f9;
}

.table-row:last-child {
  border-bottom: none;
}

.td {
  display: flex;
  align-items: center;
}

.td-rank {
  width: 88rpx;
  flex-shrink: 0;
  justify-content: center;
}

.medal {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
}

.medal-1 {
  background: linear-gradient(145deg, #ffd54f, #ffb300);
}

.medal-2 {
  background: linear-gradient(145deg, #e0e0e0, #9e9e9e);
}

.medal-3 {
  background: linear-gradient(145deg, #ffab91, #d84315);
}

.medal-num {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
}

.rank-plain {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.td-school {
  flex: 1;
  min-width: 0;
  padding: 0 12rpx;
}

.logo-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.school-logo {
  width: 100%;
  height: 100%;
}

.logo-placeholder {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
}

.school-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.name-zh {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.name-en {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.td-count {
  width: 140rpx;
  flex-shrink: 0;
  justify-content: flex-end;
  padding-right: 4rpx;
}

.count-num {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
}

.row-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 8rpx;
  font-weight: 300;
}
