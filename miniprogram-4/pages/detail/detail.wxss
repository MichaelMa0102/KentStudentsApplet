.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 图片区域 */
.image-section {
  width: 100%;
  height: 500rpx;
  overflow: hidden;
  background-color: #000;
}

.detail-image {
  width: 100%;
  height: 100%;
}

/* 内容区域 */
.content-section {
  background-color: #fff;
  margin-top: -20rpx;
  border-radius: 20rpx 20rpx 0 0;
  padding: 40rpx 30rpx;
}

.title-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.detail-type {
  font-size: 24rpx;
  color: #999;
  background-color: #f0f0f0;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.divider {
  height: 2rpx;
  background-color: #f0f0f0;
  margin: 30rpx 0;
}

/* 信息区域 */
.info-section {
  margin-bottom: 30rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.info-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
}

/* 详细内容区域 */
.content-section-inner {
  margin-bottom: 40rpx;
}

.content-label {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
}

/* 按钮区域 */
.button-section {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}

.back-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.back-button::after {
  border: none;
}

.back-button:active {
  opacity: 0.8;
}
