/* 全局容器 */
.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
  width: 100%;
  overflow-x: hidden;
}

/* 顶部导航栏 */
.top-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.user-avatar-small {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 15rpx;
  border: 2rpx solid #f0f0f0;
}

.welcome-text {
  font-size: 28rpx;
  color: #333;
}

.nav-center {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trophy-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.nav-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.dropdown-icon {
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}

.nav-right {
  flex: 1;
  text-align: right;
}

.nav-right-menu {
  flex: 1;
  text-align: right;
  padding: 10rpx;
}

.nav-icon {
  font-size: 36rpx;
  color: #666;
}

/* 轮播图区域 - 扩展宽度使其更宽，边缘到边缘 */
.swiper-section {
  margin-bottom: 20rpx;
  margin-left: 0;
  margin-right: 0;
  width: 100%;
  position: relative;
}

.swiper-container {
  width: 100%;
  height: 550rpx;
  overflow: hidden;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.swiper-item-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
}

.swiper-image {
  width: 100%;
  height: 100%;
  display: block;
}

.swiper-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  padding: 30rpx 20rpx 20rpx;
}

.swiper-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 轮播图控制 */
.swiper-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 15rpx 30rpx;
  padding: 15rpx 40rpx;
  background-color: #fff;
  border-radius: 50rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.control-btn {
  width: 50rpx;
  height: 50rpx;
  background: #ff4757;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.control-info {
  color: #333;
  font-size: 26rpx;
}

.current-index {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4757;
}

.total-count {
  opacity: 0.6;
}

/* 主要分类按钮 */
.category-buttons {
  display: flex;
  padding: 0 30rpx;
  margin-bottom: 25rpx;
}

.category-btn {
  flex: 1;
  height: 140rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.category-btn:first-child {
  margin-right: 20rpx;
}

.category-btn-left {
  background: linear-gradient(135deg, #ff6b9d 0%, #ff8fab 100%);
}

.category-btn-right {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.category-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.category-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 服务图标网格 */
.service-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 30rpx;
  margin-bottom: 25rpx;
  justify-content: space-between;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx 5rpx;
  width: 20%;
  box-sizing: border-box;
}

.service-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.service-emoji {
  font-size: 40rpx;
}

.service-name {
  font-size: 22rpx;
  color: #333;
  text-align: center;
  line-height: 1.2;
}

/* 最新OFFER更新 */
.offer-section {
  background-color: #fff;
  margin: 0 30rpx 20rpx;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.more-link {
  font-size: 26rpx;
  color: #999;
}

.offer-list {
  display: flex;
  overflow-x: auto;
}

.offer-card {
  flex-shrink: 0;
  width: 160rpx;
}

.offer-card:not(:last-child) {
  margin-right: 15rpx;
}

.offer-card {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.offer-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.offer-logo-img {
  width: 100%;
  height: 100%;
}

.offer-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.offer-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4757;
  margin-bottom: 6rpx;
}

.offer-name {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

