/* OFFER数据管理样式 */
.offer-management-container {
  height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background: #1e3c72;
  padding: 0 30rpx;
}

.header-left {
  width: 60rpx;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-right {
  width: 60rpx;
  text-align: right;
}

.back-icon {
  color: white;
  font-size: 44rpx;
  font-weight: bold;
}

.header-title {
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

.add-icon {
  color: white;
  font-size: 44rpx;
  font-weight: bold;
}

/* 搜索和筛选 */
.search-section {
  padding: 15rpx 20rpx;
  background: white;
  margin-bottom: 15rpx;
}

.search-bar {
  display: flex;
  margin-bottom: 15rpx;
}

.search-input {
  flex: 1;
  height: 70rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 35rpx;
  padding: 0 25rpx;
  font-size: 26rpx;
  background: #f8f8f8;
}

.search-btn {
  width: 100rpx;
  height: 70rpx;
  background: #1e90ff;
  color: white;
  border: none;
  border-radius: 35rpx;
  font-size: 26rpx;
  margin-left: 15rpx;
}

.filter-bar {
  display: flex;
  align-items: center;
}

.filter-picker {
  flex: 1;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 12rpx 15rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
  border: 2rpx solid #e8e8e8;
}

.filter-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
}

.filter-value {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

/* 数据列表 */
.data-list {
  flex: 1;
  background: white;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
}

.list-header {
  display: flex;
  padding: 20rpx;
  background: #f8f8f8;
  border-bottom: 2rpx solid #e8e8e8;
  font-weight: bold;
  font-size: 26rpx;
  color: #333;
}

.header-rank {
  width: 80rpx;
  text-align: center;
}

.header-school {
  flex: 1;
  text-align: left;
}

.header-count {
  width: 150rpx;
  text-align: center;
}

.header-action {
  width: 200rpx;
  text-align: center;
}

.list-content {
  flex: 1;
  overflow-y: auto;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

.item-rank {
  width: 80rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #1e90ff;
}

.item-school {
  flex: 1;
  display: flex;
  align-items: center;
}

.school-logo {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  margin-right: 15rpx;
}

.logo-placeholder {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #999;
  margin-right: 15rpx;
}

.school-info {
  flex: 1;
}

.school-name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.school-english {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.item-count {
  width: 150rpx;
  text-align: center;
}

.count-input {
  width: 100rpx;
  height: 60rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 10rpx;
  font-size: 26rpx;
  text-align: center;
}

.item-action {
  width: 200rpx;
  display: flex;
  justify-content: space-around;
}

.edit-btn {
  width: 80rpx;
  height: 50rpx;
  background: #1e90ff;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.delete-btn {
  width: 80rpx;
  height: 50rpx;
  background: #ff4d4f;
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 500rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background: #f8f8f8;
}

.modal-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 30rpx 20rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  background: #f8f8f8;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn {
  flex: 1;
  height: 80rpx;
  background: #f0f0f0;
  color: #333;
  border: none;
  font-size: 28rpx;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  background: #1e90ff;
  color: white;
  border: none;
  font-size: 28rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .header-rank {
    width: 60rpx;
  }
  
  .header-count {
    width: 120rpx;
  }
  
  .header-action {
    width: 160rpx;
  }
  
  .item-rank {
    width: 60rpx;
  }
  
  .item-count {
    width: 120rpx;
  }
  
  .item-action {
    width: 160rpx;
  }
  
  .edit-btn,
  .delete-btn {
    width: 70rpx;
    font-size: 22rpx;
  }
}