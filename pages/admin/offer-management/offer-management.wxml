<view class="offer-management-container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-left" bindtap="onBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="header-center">
      <text class="header-title">OFFER数据管理</text>
    </view>
    <view class="header-right" bindtap="showAddModal">
      <text class="add-icon">+</text>
    </view>
  </view>

  <!-- 搜索和筛选 -->
  <view class="search-section">
    <view class="search-bar">
      <input 
        class="search-input" 
        placeholder="搜索学校名称" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <button class="search-btn" bindtap="onSearch">搜索</button>
    </view>
    <view class="filter-bar">
      <picker class="filter-picker" range="{{years}}" value="{{selectedYear}}" bindchange="onYearChange">
        <view class="filter-item">
          <text class="filter-label">年份：</text>
          <text class="filter-value">{{years[selectedYear]}}</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 数据列表 -->
  <view class="data-list">
    <view class="list-header">
      <text class="header-rank">排名</text>
      <text class="header-school">学校名称</text>
      <text class="header-count">录取数量</text>
      <text class="header-action">操作</text>
    </view>
    
    <scroll-view class="list-content" scroll-y>
      <view class="list-item" wx:for="{{offerList}}" wx:key="id">
        <text class="item-rank">{{item.rank}}</text>
        <view class="item-school">
          <image wx:if="{{item.logo}}" class="school-logo" src="{{item.logo}}" mode="aspectFill" />
          <text wx:else class="logo-placeholder">{{item.nameZh[0]}}</text>
          <view class="school-info">
            <text class="school-name">{{item.nameZh}}</text>
            <text class="school-english">{{item.nameEn}}</text>
          </view>
        </view>
        <view class="item-count">
          <input 
            class="count-input" 
            type="number" 
            value="{{item.count}}" 
            bindinput="onCountChange" 
            data-id="{{item.id}}"
          />
        </view>
        <view class="item-action">
          <button class="edit-btn" bindtap="showEditModal" data-item="{{item}}">编辑</button>
          <button class="delete-btn" bindtap="confirmDelete" data-id="{{item.id}}">删除</button>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 添加/编辑弹窗 -->
  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{isEdit ? '编辑OFFER' : '添加OFFER'}}</text>
        <text class="modal-close" bindtap="hideModal">×</text>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">排名</text>
          <input 
            class="form-input" 
            type="number" 
            value="{{formData.rank}}" 
            bindinput="onFormInput" 
            data-field="rank"
          />
        </view>
        <view class="form-item">
          <text class="form-label">学校中文名</text>
          <input 
            class="form-input" 
            value="{{formData.nameZh}}" 
            bindinput="onFormInput" 
            data-field="nameZh"
          />
        </view>
        <view class="form-item">
          <text class="form-label">学校英文名</text>
          <input 
            class="form-input" 
            value="{{formData.nameEn}}" 
            bindinput="onFormInput" 
            data-field="nameEn"
          />
        </view>
        <view class="form-item">
          <text class="form-label">录取数量</text>
          <input 
            class="form-input" 
            type="number" 
            value="{{formData.count}}" 
            bindinput="onFormInput" 
            data-field="count"
          />
        </view>
        <view class="form-item">
          <text class="form-label">学校Logo</text>
          <input 
            class="form-input" 
            value="{{formData.logo}}" 
            bindinput="onFormInput" 
            data-field="logo"
            placeholder="输入图片URL"
          />
        </view>
      </view>
      <view class="modal-footer">
        <button class="cancel-btn" bindtap="hideModal">取消</button>
        <button class="confirm-btn" bindtap="saveOffer">保存</button>
      </view>
    </view>
  </view>
</view>