/* 全局容器 */
.container {
  padding: 0;
  background: linear-gradient(180deg, #f8f6ff 0%, #f0f4f8 35%, #eef2f6 100%);
  min-height: 100vh;
  padding-bottom: 100rpx;
  width: 100%;
  overflow-x: hidden;
}

/* 顶部导航栏 */
.top-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.nav-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.user-avatar-small {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 15rpx;
  border: 2rpx solid #f0f0f0;
}

.welcome-text {
  font-size: 28rpx;
  color: #333;
}

.nav-center {
  flex: 2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 1rpx;
}

.nav-right {
  flex: 1;
  text-align: right;
}

.nav-right-menu {
  flex: 1;
  text-align: right;
  padding: 10rpx;
}

.nav-icon {
  font-size: 36rpx;
  color: #666;
}

/* 轮播图区域 - 扩展宽度使其更宽，边缘到边缘 */
.swiper-section {
  margin-bottom: 20rpx;
  margin-left: 0;
  margin-right: 0;
  width: 100%;
  position: relative;
}

.swiper-container {
  width: 100%;
  height: 550rpx;
  overflow: hidden;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

.swiper-item-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
}

.swiper-image {
  width: 100%;
  height: 100%;
  display: block;
}

.swiper-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.6), transparent);
  padding: 30rpx 20rpx 20rpx;
}

.swiper-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 轮播图控制 */
.swiper-controls {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 15rpx 28rpx 8rpx;
  padding: 15rpx 40rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.control-btn {
  width: 50rpx;
  height: 50rpx;
  background: #ff4757;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.control-info {
  color: #333;
  font-size: 26rpx;
}

.current-index {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4757;
}

.total-count {
  opacity: 0.6;
}

/* 升学榜单入口 */
.rank-section {
  margin: 8rpx 28rpx 32rpx;
}

.rank-section-head {
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}

.rank-section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 0.5rpx;
}

.rank-section-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8892a6;
  line-height: 1.4;
}

.rank-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.12);
}

.rank-card:active {
  opacity: 0.92;
  transform: scale(0.99);
}

.rank-card--featured {
  margin-bottom: 20rpx;
  min-height: 168rpx;
}

.rank-card-bg {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 48%, #f093fb 100%);
  opacity: 1;
}

.rank-card-bg::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.rank-card-inner {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
}

.rank-card-inner--stack {
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 28rpx 24rpx;
  min-height: 200rpx;
}

.rank-card-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.rank-card-icon-wrap--light {
  margin-bottom: 0;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.rank-card-emoji {
  font-size: 44rpx;
}

.rank-card-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.rank-card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.rank-card-name--sm {
  font-size: 30rpx;
  color: #1a1a2e;
  text-shadow: none;
}

.rank-card-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.45;
}

.rank-card-desc--sm {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8892a6;
}

.rank-card-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 300;
  flex-shrink: 0;
  padding-left: 12rpx;
}

.rank-card-badge {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  z-index: 2;
  font-size: 20rpx;
  color: #fff;
  background: rgba(255, 71, 87, 0.95);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.rank-row {
  display: flex;
  gap: 20rpx;
}

.rank-card--half {
  flex: 1;
  min-width: 0;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
}

.rank-card--mint {
  background: linear-gradient(180deg, #ffffff 0%, #f0fdf9 100%);
  border: 1rpx solid rgba(45, 212, 191, 0.25);
}

.rank-card--lavender {
  background: linear-gradient(180deg, #ffffff 0%, #faf5ff 100%);
  border: 1rpx solid rgba(167, 139, 250, 0.3);
}

.rank-card--mint .rank-card-icon-wrap,
.rank-card--lavender .rank-card-icon-wrap {
  background: linear-gradient(145deg, #f8fafc, #fff);
}

/* 最新OFFER更新 */
.offer-section {
  background: rgba(255, 255, 255, 0.95);
  margin: 0 28rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-header-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.more-link {
  font-size: 26rpx;
  color: #999;
}

.offer-list {
  display: flex;
  overflow-x: auto;
}

.offer-card {
  flex-shrink: 0;
  width: 160rpx;
}

.offer-card:not(:last-child) {
  margin-right: 15rpx;
}

.offer-card {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.offer-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.offer-logo-img {
  width: 100%;
  height: 100%;
}

.offer-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.offer-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff4757;
  margin-bottom: 6rpx;
}

.offer-name {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

/* 管理员相关样式 */
.rank-card-badge--admin {
  background: rgba(30, 144, 255, 0.95);
}

.rank-card--admin {
  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
}

.rank-card--admin .rank-card-bg {
  background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
}

