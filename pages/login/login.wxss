/* pages/login/login.wxss */.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 100rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.app-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 15rpx;
}

.app-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 登录区域 */
.login-section {
  width: 100%;
  max-width: 600rpx;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 20rpx;
}

.nickname {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 按钮区域 */
.button-section {
  margin-bottom: 40rpx;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: #fff;
  color: #667eea;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.login-btn::after {
  border: none;
}

.login-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.logout-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  opacity: 0.8;
}

/* 用户协议 */
.agreement-section {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.agreement-text {
  color: rgba(255, 255, 255, 0.8);
}

.agreement-link {
  color: #fff;
  text-decoration: underline;
  margin: 0 5rpx;
}

/* 底部装饰 */
.footer-decoration {
  position: absolute;
  bottom: 60rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
