.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container--no-hero .content-section {
  margin-top: 0;
}

/* 图片区域 */
.image-section {
  width: 100%;
  height: 500rpx;
  overflow: hidden;
  background-color: #000;
}

.detail-image {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  padding: 80rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.placeholder-hint {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 16rpx;
}

/* 内容区域 */
.content-section {
  padding: 20rpx 30rpx 40rpx;
}

.title-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.detail-type {
  font-size: 24rpx;
  color: #999;
  background-color: #f0f0f0;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.divider {
  height: 2rpx;
  background-color: #f0f0f0;
  margin: 30rpx 0;
}

/* 信息区域 */
.info-section {
  margin-bottom: 30rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.info-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
}

/* 详细内容区域 */
.content-section-inner {
  margin-bottom: 40rpx;
}

.content-label {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
}

/* 按钮区域 */
.button-section {
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}

.back-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: none;
}

.back-button::after {
  border: none;
}

.back-button:active {
  opacity: 0.8;
}

/* 录取案例表格样式 */
.case-table {
  margin-top: 10rpx;
}

.table-header {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  font-weight: bold;
  color: #666;
  font-size: 28rpx;
}

.header-name {
  flex: 1;
}

.header-offer {
  flex: 1;
}

.header-class {
  flex: 1;
}

.table-body {
  margin-top: 8rpx;
}

.table-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  align-items: center;
}

.row-name {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.student-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  color: #fff;
}

.tag.ED {
  background-color: #ff6b81;
}

.tag.RD {
  background-color: #ff7043;
}

.row-offer {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.offer-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.year-text {
  font-size: 26rpx;
  color: #666;
}

.row-class {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.class-text {
  font-size: 28rpx;
  color: #333;
}
